{
  "name": "hanson-wong-portfolio",
  "compatibility_date": "2026-07-21",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "preview_urls": false,
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "routes": [
    { "pattern": "www.hansonwong.au", "custom_domain": true },
    { "pattern": "hansonwong.au", "custom_domain": true }
  ]
}
